## 五、双角色路由（go_router）

```dart
// app/router/app_router.dart
@riverpod
GoRouter router(RouterRef ref) {
  final user = ref.watch(userNotifierProvider);

  return GoRouter(
    initialLocation: '/welcome',
    redirect: (context, state) {
      final isLoggedIn = user != null;
      final isAuthRoute = state.matchedLocation.startsWith('/welcome') ||
                          state.matchedLocation.startsWith('/login');
      if (!isLoggedIn && !isAuthRoute) return '/welcome';
      if (isLoggedIn && isAuthRoute) {
        return user.role == UserRole.petOwner ? '/home' : '/provider-home';
      }
      return null;
    },
    routes: [
      // ─── Auth ───────────────────────────────────
      GoRoute(path: '/welcome',     builder: (_, __) => const WelcomePage()),
      GoRoute(path: '/login',       builder: (_, __) => const LoginPage()),
      GoRoute(path: '/login-phone', builder: (_, __) => const LoginPhonePage()),

      // ─── 宠物主 Shell (4 tabs) ───────────────────
      ShellRoute(
        builder: (_, __, child) => PetOwnerShell(child: child),
        routes: [
          GoRoute(path: '/home',   builder: (_, __) => const HomePage()),
          GoRoute(path: '/pets',   builder: (_, __) => const PetsPage()),
          GoRoute(path: '/chat',   builder: (_, __) => const ChatPage()),
          GoRoute(path: '/my',     builder: (_, __) => const MyPage()),
        ],
      ),

      // ─── 看护师 Shell (2 tabs) ───────────────────
      ShellRoute(
        builder: (_, __, child) => ProviderShell(child: child),
        routes: [
          GoRoute(path: '/provider-home', builder: (_, __) => const ProviderHomePage()),
          GoRoute(path: '/work-tab',      builder: (_, __) => const WorkTabPage()),
        ],
      ),

      // ─── packageUser ────────────────────────────
      GoRoute(path: '/user-profile',          builder: (_, __) => const UserProfilePage()),
      GoRoute(path: '/identity-verification', builder: (_, __) => const IdentityVerificationPage()),
      GoRoute(path: '/phone-change',          builder: (_, __) => const PhoneChangePage()),
      GoRoute(path: '/wallet',                builder: (_, __) => const WalletPage()),
      GoRoute(path: '/wallet-detail',         builder: (_, __) => const WalletDetailPage()),
      GoRoute(path: '/withdraw',              builder: (_, __) => const WithdrawPage()),
      GoRoute(path: '/stored-card',           builder: (_, __) => const StoredCardPage()),
      GoRoute(path: '/insurance',             builder: (_, __) => const InsurancePage()),
      GoRoute(path: '/coupons',               builder: (_, __) => const CouponsPage()),
      GoRoute(path: '/favorites',             builder: (_, __) => const FavoritesPage()),
      GoRoute(path: '/face-verify',           builder: (_, __) => const FaceVerifyPage()),
      GoRoute(path: '/member-center',         builder: (_, __) => const MemberCenterPage()),
      GoRoute(path: '/customer-service',      builder: (_, __) => const CustomerServicePage()),
      GoRoute(path: '/agreement',             builder: (_, __) => const AgreementPage()),
      GoRoute(path: '/platform-rules',        builder: (_, __) => const PlatformRulesPage()),
      GoRoute(path: '/about',                 builder: (_, __) => const AboutPage()),

      // ─── packageOrder ───────────────────────────
      GoRoute(path: '/order',                 builder: (_, __) => const OrderPage()),
      GoRoute(path: '/provider-detail/:id',   builder: (_, s) => ProviderDetailPage(id: s.pathParameters['id']!)),
      GoRoute(path: '/select-service',        builder: (_, __) => const SelectServicePage()),
      GoRoute(path: '/checkout',              builder: (_, __) => const CheckoutPage()),
      GoRoute(path: '/order-detail/:id',      builder: (_, s) => OrderDetailPage(id: s.pathParameters['id']!)),
      GoRoute(path: '/review-order/:id',      builder: (_, s) => ReviewOrderPage(id: s.pathParameters['id']!)),
      GoRoute(path: '/claim-apply',           builder: (_, __) => const ClaimApplyPage()),
      GoRoute(path: '/pending-payment',       builder: (_, __) => const PendingPaymentPage()),
      GoRoute(path: '/payment-success',       builder: (_, __) => const PaymentSuccessPage()),
      GoRoute(path: '/order-date-edit',       builder: (_, __) => const OrderDateEditPage()),
      GoRoute(path: '/order-service-edit',    builder: (_, __) => const OrderServiceEditPage()),
      GoRoute(path: '/order-address-edit',    builder: (_, __) => const OrderAddressEditPage()),
      GoRoute(path: '/refund-apply',          builder: (_, __) => const RefundApplyPage()),
      GoRoute(path: '/refund-detail/:id',     builder: (_, s) => RefundDetailPage(id: s.pathParameters['id']!)),

      // ─── packageManage ──────────────────────────
      GoRoute(path: '/address-list',          builder: (_, __) => const AddressListPage()),
      GoRoute(path: '/address-edit',          builder: (_, __) => const AddressEditPage()),
      GoRoute(path: '/pet-add',               builder: (_, __) => const PetAddPage()),
      GoRoute(path: '/pet-detail/:id',        builder: (_, s) => PetDetailPage(id: s.pathParameters['id']!)),
      GoRoute(path: '/provider-order-detail', builder: (_, __) => const ProviderOrderDetailPage()),
      GoRoute(path: '/petsitter-application', builder: (_, __) => const PetsitterApplicationPage()),
      GoRoute(path: '/petsitter-list',        builder: (_, __) => const PetsitterListPage()),
      GoRoute(path: '/service-manage',        builder: (_, __) => const ServiceManagePage()),
      GoRoute(path: '/service-publish',       builder: (_, __) => const ServicePublishPage()),
      GoRoute(path: '/deposit',               builder: (_, __) => const DepositPage()),

      // ─── packageProvider ────────────────────────
      GoRoute(path: '/clockin',               builder: (_, __) => const ClockinPage()),
      GoRoute(path: '/report-issue',          builder: (_, __) => const ReportIssuePage()),
      GoRoute(path: '/clockin-record',        builder: (_, __) => const ClockinRecordPage()),
      GoRoute(path: '/clockin-tasks',         builder: (_, __) => const ClockinTasksPage()),
      GoRoute(path: '/clockin-task-detail/:id', builder: (_, s) => ClockinTaskDetailPage(id: s.pathParameters['id']!)),

      // ─── 其他 ────────────────────────────────────
      GoRoute(path: '/search',                builder: (_, __) => const SearchPage()),
      GoRoute(path: '/services',              builder: (_, __) => const ServicesPage()),
      GoRoute(path: '/chatroom/:id',          builder: (_, s) => ChatroomPage(id: s.pathParameters['id']!)),
    ],
  );
}
