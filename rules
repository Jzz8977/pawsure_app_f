## 八、pubspec.yaml 完整依赖

```yaml
dependencies:
  flutter:
    sdk: flutter
  flutter_localizations:
    sdk: flutter

  # 状态管理
  flutter_riverpod: ^2.5.1
  riverpod_annotation: ^2.3.5

  # 路由
  go_router: ^13.2.0

  # 网络
  dio: ^5.4.3
  retrofit: ^4.1.0

  # 本地存储
  flutter_secure_storage: ^9.0.0
  shared_preferences: ^2.2.3
